<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BookingSystem</title>

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/BookingSystem.styles.css" asp-append-version="true" />

    <style>
        :root {
            --nav-bg: #ffffff;
            --primary-dark: #1a3a5c;
            --accent-blue: #3b82f6;
        }

        body {
            font-family: 'Poppins', sans-serif;
            background-color: #f8fafc;
            color: #1e293b;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        /* Modern Navbar */
        .navbar {
            background: var(--nav-bg) !important;
            box-shadow: 0 2px 15px rgba(0,0,0,0.04);
            padding: 0.8rem 0;
            border-bottom: 1px solid #f1f5f9 !important;
        }

        .navbar-brand {
            font-weight: 700;
            color: var(--primary-dark) !important;
            letter-spacing: -0.5px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

            .navbar-brand i {
                color: var(--accent-blue);
                font-size: 1.4rem;
            }

        .nav-link {
            font-weight: 500;
            color: #64748b !important;
            padding: 0.5rem 1.2rem !important;
            transition: all 0.2s;
            font-size: 0.95rem;
        }

            .nav-link:hover {
                color: var(--primary-dark) !important;
            }

        .nav-item.active .nav-link {
            color: var(--accent-blue) !important;
        }

        /* Main Content area */
        main {
            flex: 1;
        }

        /* Modern Footer */
        .main-footer {
            background: #ffffff;
            border-top: 1px solid #f1f5f9;
            padding: 1.5rem 0;
            margin-top: auto;
        }

        .footer-content {
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: 0.85rem;
            color: #94a3b8;
        }

        .footer-links a {
            color: #64748b;
            text-decoration: none;
            margin-left: 1.5rem;
            transition: color 0.2s;
        }

            .footer-links a:hover {
                color: var(--primary-dark);
            }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light sticky-top">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-controller="Booking" asp-action="Index">
                    <i class="bi bi-calendar2-check-fill"></i> BookingSystem
                </a>
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-end">
                    <ul class="navbar-nav">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Booking" asp-action="Index">Dashboard</a>
                        </li>
                        @* <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Bookings" asp-action="History">My Bookings</a>
                        </li> *@
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy Policy</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container-fluid p-0">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="main-footer">
        <div class="container">
            <div class="footer-content">
                <div>
                    &copy; 2026 <strong>BookingSystem</strong>. All rights reserved.
                </div>
                <div class="footer-links">
                    <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                    <a href="#">Support</a>
                    @await RenderSectionAsync("footersection", required: false)
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>