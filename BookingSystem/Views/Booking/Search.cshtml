@model IEnumerable<BookingSystem.Models.Booking>

@{
    ViewData["Title"] = "Search Results";
}

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

<style>
    :root {
        --primary-dark: #1a3a5c;
        --bg-gradient: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%);
    }

    body {
        background: var(--bg-gradient);
        font-family: 'Poppins', sans-serif;
        min-height: 100vh;
    }

    .search-container {
        padding: 3rem 1.5rem;
    }

    .glass-card {
        background: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(10px);
        border-radius: 24px;
        border: 1px solid rgba(255, 255, 255, 0.5);
        box-shadow: 0 20px 50px rgba(0,0,0,0.05);
        overflow: hidden;
        padding: 2rem;
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
    }

    .title-section h2 {
        font-weight: 700;
        color: var(--primary-dark);
        margin-bottom: 0.5rem;
    }

    .btn-create {
        background: var(--primary-dark);
        color: white;
        padding: 10px 24px;
        border-radius: 12px;
        text-decoration: none;
        font-weight: 500;
        transition: 0.3s;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .btn-create:hover {
            background: #0f172a;
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(26, 58, 92, 0.2);
        }

    /* Table Styling */
    .custom-table {
        background: white;
        border-radius: 16px;
        overflow: hidden;
    }

    .table thead {
        background: #f8fafc;
    }

        .table thead th {
            border: none;
            color: #64748b;
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            padding: 1.25rem 1rem;
        }

    .table tbody tr {
        transition: 0.2s;
        border-bottom: 1px solid #f1f5f9;
    }

        .table tbody tr:hover {
            background: #fdfdfd;
        }

    .table tbody td {
        padding: 1.25rem 1rem;
        vertical-align: middle;
        font-size: 14px;
        color: #334155;
    }

    .service-badge {
        background: #eff6ff;
        color: #3b82f6;
        padding: 4px 12px;
        border-radius: 8px;
        font-weight: 600;
        font-size: 12px;
    }

    .action-icons {
        display: flex;
        gap: 12px;
        font-size: 1.1rem;
    }

        .action-icons a {
            transition: 0.2s;
        }

    .edit-icon {
        color: #3b82f6;
    }

    .details-icon {
        color: #10b981;
    }

    .delete-icon {
        color: #ef4444;
    }

    .action-icons a:hover {
        transform: scale(1.2);
    }
</style>

<div class="container search-container">
    <div class="glass-card">
        <div class="page-header">
            <div class="title-section">
                <h2><i class="bi bi-search me-2"></i>Booking Explorer</h2>
                <p class="text-muted small mb-0">Found @Model.Count() records matching your criteria</p>
            </div>
            <a asp-action="Create" class="btn-create">
                <i class="bi bi-plus-circle"></i> New Booking
            </a>
        </div>

        <div class="table-responsive custom-table">
            <table class="table mb-0">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Customer</th>
                        <th>Contact</th>
                        <th>Service</th>
                        <th>Appointment Date</th>
                        <th class="text-center">Manage</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="text-muted fw-bold">#@item.BookingId</td>
                            <td>
                                <div class="fw-semibold">@item.CustomerName</div>
                            </td>
                            <td>
                                <div class="small text-muted"><i class="bi bi-telephone me-1"></i> @item.Phone</div>
                            </td>
                            <td>
                                <span class="service-badge">@item.Service</span>
                            </td>
                            <td>
                                <div class="small">@item.AppointmentDate.ToString("MMM dd, yyyy")</div>
                                <div class="text-muted" style="font-size: 11px;">@item.AppointmentDate.ToString("hh:mm tt")</div>
                            </td>
                            <td>
                                <div class="action-icons justify-content-center">
                                    <a asp-action="Edit" asp-route-id="@item.BookingId" class="edit-icon" title="Edit"><i class="bi bi-pencil-square"></i></a>
                                    <a asp-action="Details" asp-route-id="@item.BookingId" class="details-icon" title="Details"><i class="bi bi-eye"></i></a>
                                    <a asp-action="Delete" asp-route-id="@item.BookingId" class="delete-icon" title="Delete"><i class="bi bi-trash3"></i></a>
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5">
                                <i class="bi bi-inbox text-muted" style="font-size: 3rem;"></i>
                                <p class="mt-2 text-muted">No bookings found.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>