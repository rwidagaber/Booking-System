@model BookingSystem.Models.Booking

<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

<style>
    :root {
        --primary-dark: #1a3a5c;
        --bg-gradient: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%);
    }

    .bk-wrap {
        padding: 4rem 1.5rem;
        font-family: 'Poppins', sans-serif;
        background: var(--bg-gradient);
        min-height: 90vh;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .bk-card {
        background: #ffffff;
        border: none;
        border-radius: 24px;
        max-width: 550px;
        width: 100%;
        overflow: hidden;
        box-shadow: 0 20px 50px rgba(0,0,0,0.08);
        animation: fadeInForm 0.5s ease-out;
    }

    @@keyframes fadeInForm {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .bk-header {
        background: var(--primary-dark);
        padding: 2.5rem 2.5rem 2rem;
        text-align: center;
    }

    .bk-header-icon {
        width: 50px;
        height: 50px;
        border-radius: 12px;
        background: rgba(255,255,255,0.1);
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1.25rem;
        border: 1px solid rgba(255,255,255,0.2);
        color: white;
        font-size: 1.5rem;
    }

    .bk-title {
        font-family: 'DM Serif Display', serif;
        font-size: 26px;
        color: #fff;
        margin: 0 0 6px;
        font-weight: 400;
        letter-spacing: 0.5px;
    }

    .bk-subtitle {
        font-size: 13px;
        color: rgba(255,255,255,0.6);
        margin: 0;
    }

    .bk-body {
        padding: 2.5rem;
    }

    .bk-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
    }

    .bk-field {
        margin-bottom: 1.5rem;
    }

    .bk-label {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 11px;
        font-weight: 600;
        color: #64748b;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        margin-bottom: 8px;
    }

    .bk-input {
        width: 100%;
        height: 48px;
        padding: 0 16px;
        font-size: 14px;
        font-family: 'Poppins', sans-serif;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        color: #1e293b;
        outline: none;
        transition: all 0.2s;
    }

        .bk-input:focus {
            border-color: var(--primary-dark);
            box-shadow: 0 0 0 4px rgba(26, 58, 92, 0.1);
            background: #fff;
        }

    .bk-footer {
        padding: 0 2.5rem 2.5rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .bk-hint {
        font-size: 12px;
        color: #94a3b8;
    }

    .bk-btn {
        height: 50px;
        padding: 0 2rem;
        background: var(--primary-dark);
        color: #fff;
        border: none;
        border-radius: 14px;
        font-family: 'Poppins', sans-serif;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 10px;
        transition: all 0.3s;
        box-shadow: 0 10px 15px -3px rgba(26, 58, 92, 0.2);
    }

        .bk-btn:hover {
            background: #0f172a;
            transform: translateY(-2px);
            box-shadow: 0 15px 25px -5px rgba(26, 58, 92, 0.3);
        }

    .text-danger {
        font-size: 11px;
        color: #ef4444;
        margin-top: 5px;
        display: block;
        font-weight: 500;
    }
</style>

<div class="bk-wrap">
    <div class="bk-card">

        <div class="bk-header">
            <div class="bk-header-icon">
                <i class="bi bi-calendar-plus"></i>
            </div>
            <h2 class="bk-title">Reserve Service</h2>
            <p class="bk-subtitle">Complete the form below to secure your spot</p>
        </div>

        <form asp-action="Create" method="post" class="bk-body" id="bookingForm">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="bk-row">
                <div class="bk-field">
                    <label asp-for="CustomerName" class="bk-label">
                        <i class="bi bi-person"></i> Name
                    </label>
                    <input asp-for="CustomerName" class="bk-input" placeholder="Full name" />
                    <span asp-validation-for="CustomerName" class="text-danger"></span>
                </div>
                <div class="bk-field">
                    <label asp-for="Phone" class="bk-label">
                        <i class="bi bi-telephone"></i> Phone
                    </label>
                    <input asp-for="Phone" class="bk-input" placeholder="+1..." />
                    <span asp-validation-for="Phone" class="text-danger"></span>
                </div>
            </div>

            <div class="bk-field">
                <label asp-for="Service" class="bk-label">
                    <i class="bi bi-briefcase"></i> Service Type
                </label>
                <input asp-for="Service" class="bk-input" placeholder="What service do you need?" />
                <span asp-validation-for="Service" class="text-danger"></span>
            </div>

            <div class="bk-field">
                <label asp-for="AppointmentDate" class="bk-label">
                    <i class="bi bi-clock"></i> Date & Time
                </label>
                <input asp-for="AppointmentDate" class="bk-input" type="datetime-local" />
                <span asp-validation-for="AppointmentDate" class="text-danger"></span>
            </div>
        </form>

        <div class="bk-footer">
            <a asp-action="Index" class="text-decoration-none text-muted small"><i class="bi bi-arrow-left"></i> Back</a>
            <button type="submit" form="bookingForm" class="bk-btn">
                Confirm Booking
                <i class="bi bi-chevron-right"></i>
            </button>
        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}