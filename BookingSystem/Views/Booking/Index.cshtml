@model IEnumerable<BookingSystem.Models.Booking>
@{
    ViewData["Title"] = "Manage Bookings";
}

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

<style>
    body {
        background-color: #f8f9fa;
        font-family: 'Poppins', sans-serif;
    }

    .main-card {
        border-radius: 20px;
        border: none;
        box-shadow: 0 10px 30px rgba(0,0,0,0.08);
        overflow: hidden;
    }

    .table-header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 2rem;
    }

    .btn-add {
        background: rgba(255,255,255,0.2);
        color: white;
        border: 1px solid rgba(255,255,255,0.4);
        border-radius: 10px;
        padding: 8px 20px;
        transition: 0.3s;
        text-decoration: none;
    }

        .btn-add:hover {
            background: white;
            color: #764ba2;
        }

    .table thead th {
        border: none;
        color: #6c757d;
        font-weight: 600;
        text-transform: uppercase;
        font-size: 0.8rem;
        letter-spacing: 1px;
    }

    .table tbody tr {
        transition: 0.3s;
    }

        .table tbody tr:hover {
            background-color: #f4f7ff;
            transform: scale(1.005);
        }

    .action-link {
        text-decoration: none;
        font-size: 1.2rem;
        margin: 0 5px;
        transition: 0.2s;
    }

    .edit-link {
        color: #667eea;
    }

    .details-link {
        color: #34bfa3;
    }

    .delete-link {
        color: #f4516c;
    }
</style>

<div class="container py-5">
    <div class="main-card bg-white">
        <div class="table-header d-flex justify-content-between align-items-center">
            <div>
                <h2 class="fw-bold mb-1">Booking Dashboard</h2>
                <p class="mb-0 opacity-75">Manage your upcoming appointments and customer list</p>
            </div>
            <a asp-action="Create" class="btn-add"><i class="bi bi-plus-lg me-2"></i>New Booking</a>
        </div>

        <div class="p-4">
            <table class="table align-middle">
                <thead>
                    <tr>
                        <th>Customer</th>
                        <th>Phone</th>
                        <th>Service</th>
                        <th>Appointment Date</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-bold text-dark">@item.CustomerName</td>
                            <td><i class="bi bi-telephone text-muted me-2"></i>@item.Phone</td>
                            <td><span class="badge bg-light text-primary p-2 px-3 rounded-pill">@item.Service</span></td>
                            <td>@item.AppointmentDate.ToString("MMM dd, yyyy - HH:mm")</td>
                            <td class="text-center">
                                <a asp-action="Edit" asp-route-id="@item.BookingId" class="action-link edit-link" title="Edit"><i class="bi bi-pencil-square"></i></a>
                                <a asp-action="Details" asp-route-id="@item.BookingId" class="action-link details-link" title="Details"><i class="bi bi-eye"></i></a>
                                <a asp-action="Delete" asp-route-id="@item.BookingId" class="action-link delete-link" title="Delete"><i class="bi bi-trash3"></i></a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>