@model BookingSystem.Models.Booking
@{
    ViewData["Title"] = "Edit Booking";
}

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

<style>
    :root {
        --primary-dark: #1a3a5c;
        --accent-color: #3b82f6;
        --bg-gradient: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%);
    }

    .edit-wrap {
        padding: 4rem 1.5rem;
        font-family: 'Poppins', sans-serif;
        background: var(--bg-gradient);
        min-height: 90vh;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .form-card {
        background: #ffffff;
        max-width: 600px;
        width: 100%;
        margin: 0 auto;
        border-radius: 24px;
        box-shadow: 0 20px 50px rgba(0,0,0,0.08);
        border: none;
        overflow: hidden;
        animation: fadeIn 0.5s ease-out;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(15px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .form-header {
        padding: 2.5rem 2.5rem 2rem;
        background: var(--primary-dark);
        color: white;
    }

    .form-header-icon {
        width: 45px;
        height: 45px;
        background: rgba(255,255,255,0.1);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 1rem;
        border: 1px solid rgba(255,255,255,0.2);
    }

    .input-custom {
        border-radius: 12px;
        padding: 12px 16px;
        border: 1px solid #e2e8f0;
        background: #f8fafc;
        transition: all 0.3s ease;
        font-size: 14px;
        height: 48px;
    }

        .input-custom:focus {
            background: white;
            border-color: var(--accent-color);
            box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.1);
            outline: none;
        }

    .label-custom {
        font-size: 11px;
        font-weight: 700;
        color: #64748b;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        margin-bottom: 8px;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .change-indicator {
        display: none;
        color: var(--accent-color);
        font-size: 10px;
        font-weight: 700;
        margin-left: auto;
        background: #eff6ff;
        padding: 2px 8px;
        border-radius: 6px;
    }

    .btn-save {
        background: var(--primary-dark);
        color: white;
        border: none;
        padding: 12px 30px;
        border-radius: 14px;
        font-weight: 600;
        transition: all 0.3s;
        box-shadow: 0 10px 15px -3px rgba(26, 58, 92, 0.2);
    }

        .btn-save:hover {
            background: #0f172a;
            transform: translateY(-2px);
            box-shadow: 0 15px 25px -5px rgba(26, 58, 92, 0.3);
            color: white;
        }

    .btn-cancel {
        color: #64748b;
        font-weight: 500;
        text-decoration: none;
        font-size: 14px;
        transition: 0.2s;
    }

        .btn-cancel:hover {
            color: #1e293b;
        }
</style>

<div class="edit-wrap">
    <div class="form-card">
        <div class="form-header">
            <div class="form-header-icon">
                <i class="bi bi-pencil-square fs-5"></i>
            </div>
            <h4 class="fw-bold mb-1">Edit Appointment</h4>
            <p class="mb-0 opacity-50 small">Updating Record ID: #@Model.BookingId</p>
        </div>

        <form asp-action="EditBooking" class="p-4 p-md-5">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="BookingId" />

            <div class="mb-4">
                <div class="d-flex align-items-center">
                    <label class="label-custom"><i class="bi bi-person"></i> Customer Name</label>
                    <span id="name-ind" class="change-indicator">Unsaved Change</span>
                </div>
                <input asp-for="CustomerName" class="form-control input-custom" oninput="showIndicator('name')" placeholder="Enter customer name" />
                <span asp-validation-for="CustomerName" class="text-danger small"></span>
            </div>

            <div class="row">
                <div class="col-md-6 mb-4">
                    <label class="label-custom"><i class="bi bi-phone"></i> Phone Number</label>
                    <input asp-for="Phone" class="form-control input-custom" placeholder="+1..." />
                    <span asp-validation-for="Phone" class="text-danger small"></span>
                </div>
                <div class="col-md-6 mb-4">
                    <label class="label-custom"><i class="bi bi-calendar3"></i> Date & Time</label>
                    <input asp-for="AppointmentDate" class="form-control input-custom" type="datetime-local" />
                    <span asp-validation-for="AppointmentDate" class="text-danger small"></span>
                </div>
            </div>

            <div class="mb-4">
                <label class="label-custom"><i class="bi bi-briefcase"></i> Service Selection</label>
                <input asp-for="Service" class="form-control input-custom" placeholder="Type of service" />
                <span asp-validation-for="Service" class="text-danger small"></span>
            </div>

            <div class="d-flex justify-content-between align-items-center mt-5">
                <a asp-action="Index" class="btn-cancel">
                    <i class="bi bi-x-circle me-1"></i> Discard
                </a>
                <button type="submit" class="btn btn-save">
                    <i class="bi bi-check2-circle me-1"></i> Update Booking
                </button>
            </div>
        </form>
    </div>
</div>

<script>
    function showIndicator(id) {
        const indicator = document.getElementById(id + '-ind');
        if(indicator) {
            indicator.style.display = 'inline-block';
        }
    }
</script>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}