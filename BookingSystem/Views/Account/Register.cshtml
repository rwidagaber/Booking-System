@model MVC.ViewModels.CrtUserVM

@{
    ViewData["Title"] = "Create Account";
}

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

<style>
    :root {
        --primary-dark: #1a3a5c;
        --accent-blue: #3b82f6;
        --bg-gradient: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%);
    }

    .reg-wrap {
        padding: 4rem 1.5rem;
        font-family: 'Poppins', sans-serif;
        background: var(--bg-gradient);
        min-height: 90vh;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .reg-card {
        background: #ffffff;
        border-radius: 30px;
        max-width: 600px;
        width: 100%;
        overflow: hidden;
        box-shadow: 0 25px 50px -12px rgba(0,0,0,0.1);
        animation: slideUp 0.6s ease-out;
    }

    @@keyframes slideUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .reg-header {
        background: var(--primary-dark);
        padding: 2.5rem;
        text-align: center;
        color: white;
    }

    .reg-header-icon {
        width: 60px;
        height: 60px;
        background: rgba(255,255,255,0.1);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1rem;
        border: 2px solid rgba(255,255,255,0.2);
        font-size: 1.5rem;
    }

    .reg-body {
        padding: 2.5rem 3rem;
    }

    .reg-label {
        font-size: 11px;
        font-weight: 700;
        color: #64748b;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 8px;
        display: block;
    }

    .reg-input-group {
        position: relative;
        margin-bottom: 1.25rem;
    }

        .reg-input-group i {
            position: absolute;
            left: 15px;
            top: 50%;
            transform: translateY(-50%);
            color: #94a3b8;
            transition: 0.3s;
        }

    .reg-input {
        width: 100%;
        height: 48px;
        padding: 0 15px 0 42px;
        background: #f8fafc;
        border: 1.5px solid #e2e8f0;
        border-radius: 12px;
        font-size: 14px;
        transition: all 0.3s;
    }

        .reg-input:focus {
            border-color: var(--accent-blue);
            background: white;
            box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.1);
            outline: none;
        }

            .reg-input:focus + i {
                color: var(--accent-blue);
            }

    .btn-submit {
        height: 52px;
        width: 100%;
        background: var(--primary-dark);
        color: white;
        border: none;
        border-radius: 15px;
        font-weight: 600;
        font-size: 15px;
        transition: all 0.3s;
        box-shadow: 0 10px 15px -3px rgba(26, 58, 92, 0.2);
        margin-top: 1rem;
    }

        .btn-submit:hover {
            background: #0f172a;
            transform: translateY(-2px);
            box-shadow: 0 20px 25px -5px rgba(26, 58, 92, 0.3);
        }

    .btn-back {
        display: block;
        text-align: center;
        margin-top: 1.5rem;
        color: #94a3b8;
        text-decoration: none;
        font-size: 13px;
        transition: 0.2s;
    }

        .btn-back:hover {
            color: var(--primary-dark);
        }

    .grid-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
    }

    @@media (max-width: 576px) {
        .grid-row {
            grid-template-columns: 1fr;
        }

        .reg-body {
            padding: 2rem;
        }
    }
</style>

<div class="reg-wrap">
    <div class="reg-card">
        <div class="reg-header">
            <div class="reg-header-icon">
                <i class="bi bi-person-plus-fill"></i>
            </div>
            <h3 class="fw-bold mb-1">Create Account</h3>
            <p class="opacity-50 small mb-0">Join us to start managing your bookings</p>
        </div>

        <div class="reg-body">
            <form asp-action="Register">
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                <div class="mb-4">
                    <label asp-for="UserName" class="reg-label">Choose Username</label>
                    <div class="reg-input-group">
                        <input asp-for="UserName" class="reg-input" placeholder="e.g. JohnDoe" />
                        <i class="bi bi-person"></i>
                    </div>
                    <span asp-validation-for="UserName" class="text-danger small"></span>
                </div>

                <div class="grid-row">
                    <div class="mb-4">
                        <label asp-for="Password" class="reg-label">Password</label>
                        <div class="reg-input-group">
                            <input asp-for="Password" type="password" class="reg-input" placeholder="••••••••" />
                            <i class="bi bi-lock"></i>
                        </div>
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="ConfirmPassword" class="reg-label">Confirm Password</label>
                        <div class="reg-input-group">
                            <input asp-for="ConfirmPassword" type="password" class="reg-input" placeholder="••••••••" />
                            <i class="bi bi-shield-check"></i>
                        </div>
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>
                </div>

                <div class="mb-4">
                    <label asp-for="Address" class="reg-label">Address (Optional)</label>
                    <div class="reg-input-group">
                        <input asp-for="Address" class="reg-input" placeholder="Street, City, State" />
                        <i class="bi bi-geo-alt"></i>
                    </div>
                    <span asp-validation-for="Address" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn-submit" action="login">
                    Register Account
                </button>

                <a asp-action="login" class="btn-back">
                    <i class="bi bi-arrow-left me-1"></i> Already have an account? Login here
                </a>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}