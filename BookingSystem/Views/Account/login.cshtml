@using MVC.ViewModels
@model LoginVM

@{
    ViewData["Title"] = "Secure Login";
}

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

<style>
    :root {
        --primary-dark: #1a3a5c;
        --accent-blue: #3b82f6;
        --bg-gradient: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%);
    }

    .auth-wrap {
        padding: 4rem 1.5rem;
        font-family: 'Poppins', sans-serif;
        background: var(--bg-gradient);
        min-height: 90vh;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .login-card {
        background: #ffffff;
        border-radius: 28px;
        max-width: 450px;
        width: 100%;
        overflow: hidden;
        box-shadow: 0 25px 50px -12px rgba(0,0,0,0.1);
        animation: fadeInDown 0.6s ease-out;
    }

    @@keyframes fadeInDown {
        from {
            opacity: 0;
            transform: translateY(-20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .login-header {
        background: var(--primary-dark);
        padding: 3rem 2rem;
        text-align: center;
        color: white;
    }

    .login-logo-box {
        width: 65px;
        height: 65px;
        background: rgba(255,255,255,0.1);
        border-radius: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1.5rem;
        border: 1px solid rgba(255,255,255,0.2);
        font-size: 1.8rem;
    }

    .login-body {
        padding: 2.5rem;
    }

    .input-group-custom {
        position: relative;
        margin-bottom: 1.5rem;
    }

        .input-group-custom i {
            position: absolute;
            left: 16px;
            top: 50%;
            transform: translateY(-50%);
            color: #94a3b8;
            transition: 0.3s;
        }

    .login-input {
        width: 100%;
        height: 52px;
        padding: 0 16px 0 45px;
        background: #f8fafc;
        border: 1.5px solid #e2e8f0;
        border-radius: 14px;
        font-size: 14px;
        transition: all 0.3s;
        outline: none;
    }

        .login-input:focus {
            border-color: var(--accent-blue);
            background: white;
            box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.1);
        }

            .login-input:focus + i {
                color: var(--accent-blue);
            }

    .login-label {
        font-size: 11px;
        font-weight: 700;
        color: #64748b;
        text-transform: uppercase;
        letter-spacing: 0.8px;
        margin-bottom: 8px;
        display: block;
    }

    .btn-login {
        width: 100%;
        height: 52px;
        background: var(--primary-dark);
        color: white;
        border: none;
        border-radius: 14px;
        font-weight: 600;
        font-size: 15px;
        transition: all 0.3s;
        box-shadow: 0 10px 15px -3px rgba(26, 58, 92, 0.2);
        margin-top: 1rem;
    }

        .btn-login:hover {
            background: #0f172a;
            transform: translateY(-2px);
            box-shadow: 0 20px 25px -5px rgba(26, 58, 92, 0.3);
        }

    .login-footer {
        text-align: center;
        margin-top: 1.5rem;
        font-size: 13px;
        color: #94a3b8;
    }

        .login-footer a {
            color: var(--accent-blue);
            text-decoration: none;
            font-weight: 600;
        }

    .text-danger ul {
        list-style: none;
        padding: 0;
        font-size: 12px;
        font-weight: 500;
    }
</style>

<div class="auth-wrap">
    <div class="login-card">
        <div class="login-header">
            <div class="login-logo-box">
                <i class="bi bi-shield-lock-fill"></i>
            </div>
            <h3 class="fw-bold mb-1">Welcome Back</h3>
            <p class="opacity-50 small mb-0">Please enter your credentials</p>
        </div>

        <div class="login-body">
            <form asp-action="Login">
                <div asp-validation-summary="All" class="text-danger mb-3"></div>

                <div class="mb-4">
                    <label asp-for="Username" class="login-label">Username</label>
                    <div class="input-group-custom">
                        <input asp-for="Username" class="login-input" placeholder="e.g. admin_user" />
                        <i class="bi bi-person"></i>
                    </div>
                    <span asp-validation-for="Username" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Password" class="login-label">Password</label>
                    <div class="input-group-custom">
                        <input asp-for="Password" type="password" class="login-input" placeholder="••••••••" />
                        <i class="bi bi-key"></i>
                    </div>
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn-login">
                    Sign In
                </button>

                <div class="login-footer">
                    <p>Forgot password? <a href="#">Contact Support</a></p>
                    <a asp-action="Index" asp-controller="Home" class="text-muted">
                        <i class="bi bi-arrow-left me-1"></i> Back to Home
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}